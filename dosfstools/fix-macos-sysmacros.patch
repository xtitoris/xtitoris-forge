From 77ffb87e8272760b3bb2dec8f722103b0effb801 Mon Sep 17 00:00:00 2001
From: i0ntempest <szf1234@me.com>
Date: Fri, 20 Aug 2021 21:51:24 +0800
Subject: [PATCH] Fix building on macos

---
 configure.ac        | 1 +
 src/blkdev/blkdev.c | 5 ++++-
 src/device_info.c   | 3 +++
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index 27fb06d..76882995 100644
--- a/configure.ac
+++ b/configure.ac
@@ -60,6 +60,7 @@ AC_CHECK_HEADERS([\
 		  sys/ioccom.h \
 		  sys/mkdev.h \
 		  sys/queue.h \
+		  sys/sysmacros.h \
 		  ])

 AC_CHECK_HEADERS([endian.h sys/endian.h libkern/OSByteOrder.h])
diff --git a/src/blkdev/blkdev.c b/src/blkdev/blkdev.c
index d97a4b3..13eb18c 100644
--- a/src/blkdev/blkdev.c
+++ b/src/blkdev/blkdev.c
@@ -7,12 +7,15 @@
 #include <sys/types.h>
 #include <sys/stat.h>
 #include <sys/ioctl.h>
-#include <sys/sysmacros.h>
 #include <unistd.h>
 #include <stdint.h>
 #include <stdio.h>
 #include <limits.h>

+#ifdef HAVE_SYS_SYSMACROS_H
+#include <sys/sysmacros.h>
+#endif
+
 #ifdef HAVE_LINUX_HDREG_H
 #include <linux/hdreg.h>
 #endif
diff --git a/src/device_info.c b/src/device_info.c
index 21c438f..80f7c9953 100644
--- a/src/device_info.c
+++ b/src/device_info.c
@@ -24,7 +24,10 @@
 #include <sys/types.h>
 #include <sys/stat.h>
 #include <sys/ioctl.h>
+
+#ifdef HAVE_SYS_SYSMACROS_H
 #include <sys/sysmacros.h>
+#endif

 #ifdef HAVE_LINUX_LOOP_H
 #include <linux/loop.h>
